RewriteEngine On
RewriteBase /

# Cache: assets (long), HTML (short)
<FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|css|js|woff2|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

<FilesMatch "\.(html)$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
</FilesMatch>

# Favicon
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^favicon\.ico$ assets/favicon.ico [L]

# Existing files/directories - pass through
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Root: / -> html/home.html
RewriteRule ^$ html/home.html [L]

# Pages: /about -> html/about.html
RewriteRule ^([^/]+)/?$ html/$1.html [L]

# Nested pages: /blog/article -> html/blog/article.html
RewriteRule ^(.+?)/?$ html/$1.html [L]

# 404
ErrorDocument 404 /html/404.html
